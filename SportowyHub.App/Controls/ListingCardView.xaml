<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:SportowyHub.Controls"
             xmlns:res="clr-namespace:SportowyHub.Resources.Strings"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="SportowyHub.Controls.ListingCardView"
             x:DataType="controls:ListingCardView">

    <Border BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
            StrokeThickness="0"
            Padding="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="16" />
        </Border.StrokeShape>
        <Border.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding TapCommand, Source={RelativeSource AncestorType={x:Type controls:ListingCardView}}}"
                                  CommandParameter="{Binding Listing, Source={RelativeSource AncestorType={x:Type controls:ListingCardView}}}" />
        </Border.GestureRecognizers>

        <Grid RowDefinitions="140,Auto">

            <BoxView Grid.Row="0"
                     Color="{Binding Listing.CategoryId, Source={RelativeSource AncestorType={x:Type controls:ListingCardView}}, Converter={StaticResource CategoryToColorConverter}}"
                     CornerRadius="16,16,0,0" />

            <Border Grid.Row="0"
                    BackgroundColor="{Binding ConditionBadgeColor, Source={RelativeSource AncestorType={x:Type controls:ListingCardView}}}"
                    IsVisible="{Binding HasCondition, Source={RelativeSource AncestorType={x:Type controls:ListingCardView}}}"
                    StrokeThickness="0"
                    Padding="8,4"
                    Margin="10,10,0,0"
                    HorizontalOptions="Start"
                    VerticalOptions="Start">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="6" />
                </Border.StrokeShape>
                <Label Text="{Binding ConditionText, Source={RelativeSource AncestorType={x:Type controls:ListingCardView}}}"
                       TextColor="White"
                       FontFamily="OpenSansSemibold"
                       FontSize="10" />
            </Border>

            <ImageButton Grid.Row="0"
                         Source="{Binding IsFavorited, Source={RelativeSource AncestorType={x:Type controls:ListingCardView}}, Converter={StaticResource BoolToHeartConverter}}"
                         Command="{Binding ToggleFavoriteCommand, Source={RelativeSource AncestorType={x:Type controls:ListingCardView}}}"
                         CommandParameter="{Binding Listing, Source={RelativeSource AncestorType={x:Type controls:ListingCardView}}}"
                         SemanticProperties.Description="{x:Static res:AppResources.A11yFavoriteButton}"
                         HorizontalOptions="End"
                         VerticalOptions="Start"
                         Margin="0,8,8,0"
                         Padding="6"
                         WidthRequest="32"
                         HeightRequest="32"
                         BackgroundColor="Transparent">
                <ImageButton.Behaviors>
                    <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                </ImageButton.Behaviors>
            </ImageButton>

            <VerticalStackLayout Grid.Row="1" Padding="10,8,10,10" Spacing="2">
                <Label Text="{Binding Listing.Title, Source={RelativeSource AncestorType={x:Type controls:ListingCardView}}}"
                       FontSize="14"
                       FontFamily="OpenSansSemibold"
                       LineBreakMode="TailTruncation"
                       MaxLines="1"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                <Label FontSize="16"
                       FontFamily="OpenSansSemibold"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}">
                    <Label.Text>
                        <MultiBinding StringFormat="{}{0} {1}">
                            <Binding Path="Listing.Price" Source="{RelativeSource AncestorType={x:Type controls:ListingCardView}}" />
                            <Binding Path="Listing.Currency" Source="{RelativeSource AncestorType={x:Type controls:ListingCardView}}" />
                        </MultiBinding>
                    </Label.Text>
                </Label>
                <HorizontalStackLayout Spacing="4"
                                       IsVisible="{Binding Listing.ViewCount, Source={RelativeSource AncestorType={x:Type controls:ListingCardView}}, Converter={StaticResource IntToBoolConverter}, FallbackValue=False}">
                    <Image Source="icon_eye.png"
                           WidthRequest="12"
                           HeightRequest="12"
                           VerticalOptions="Center">
                        <Image.Behaviors>
                            <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                        </Image.Behaviors>
                    </Image>
                    <Label Text="{Binding Listing.ViewCount, Source={RelativeSource AncestorType={x:Type controls:ListingCardView}}, Converter={StaticResource ViewCountFormatConverter}, FallbackValue=''}"
                           FontSize="11"
                           FontFamily="OpenSansRegular"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

        </Grid>
    </Border>

</ContentView>
