<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SportowyHub.ViewModels"
             xmlns:models="clr-namespace:SportowyHub.Models.Api"
             xmlns:controls="clr-namespace:SportowyHub.Controls"
             xmlns:res="clr-namespace:SportowyHub.Resources.Strings"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="SportowyHub.Views.Home.HomePage"
             x:DataType="vm:HomeViewModel"
             Title="{x:Static res:AppResources.HomeTitle}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Background}, Dark={StaticResource BackgroundDark}}">

    <Grid>
        <ScrollView x:Name="MainScroll">
            <VerticalStackLayout Padding="16,8,16,0" Spacing="12">

                <!-- Header Bar -->
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,0">
                    <Label Text="SportowyHub"
                           FontFamily="OpenSansSemibold"
                           FontSize="26"
                           MaxLines="1"
                           LineBreakMode="NoWrap"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                           VerticalOptions="Center" />
                    <HorizontalStackLayout Grid.Column="2" Spacing="8">
                        <Border WidthRequest="38"
                                HeightRequest="38"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource IconButtonStrokeDark}}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource IconButtonBgDark}}"
                                SemanticProperties.Description="{x:Static res:AppResources.A11yToggleThemeButton}"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="19" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleThemeCommand}" />
                            </Border.GestureRecognizers>
                            <Image Source="{AppThemeBinding Light=icon_theme_toggle.png, Dark=icon_theme_toggle_dark.png}"
                                   HeightRequest="20"
                                   WidthRequest="20"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <Border WidthRequest="38"
                                HeightRequest="38"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource IconButtonStrokeDark}}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource IconButtonBgDark}}"
                                SemanticProperties.Description="{x:Static res:AppResources.A11yFavoritesButton}"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="19" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToFavoritesCommand}" />
                            </Border.GestureRecognizers>
                            <Image Source="{AppThemeBinding Light=icon_heart_outline.png, Dark=icon_heart_outline_dark.png}"
                                   HeightRequest="20"
                                   WidthRequest="20"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <Border WidthRequest="38"
                                HeightRequest="38"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource IconButtonStrokeDark}}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource IconButtonBgDark}}"
                                SemanticProperties.Description="{x:Static res:AppResources.A11yCartButton}"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="19" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToCartCommand}" />
                            </Border.GestureRecognizers>
                            <Image Source="{AppThemeBinding Light=icon_cart.png, Dark=icon_cart_dark.png}"
                                   HeightRequest="20"
                                   WidthRequest="20"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                    </HorizontalStackLayout>
                </Grid>

                <!-- Search Bar -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource SearchBarBackground}, Dark={StaticResource SearchBarBackgroundDark}}"
                        StrokeThickness="{AppThemeBinding Light=0, Dark=1}"
                        Stroke="{AppThemeBinding Light=Transparent, Dark={StaticResource BorderDark}}"
                        SemanticProperties.Description="{x:Static res:AppResources.A11ySearchBar}"
                        SemanticProperties.Hint="{x:Static res:AppResources.SearchPlaceholder}"
                        Padding="16,12">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToSearchCommand}" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Image Source="icon_search_bar.png"
                               HeightRequest="20"
                               WidthRequest="20"
                               VerticalOptions="Center">
                            <Image.Behaviors>
                                <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                            </Image.Behaviors>
                        </Image>
                        <Label Grid.Column="1"
                               Text="{x:Static res:AppResources.SearchPlaceholder}"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               VerticalOptions="Center"
                               Margin="12,0,0,0"
                               FontSize="14" />
                        <Image Grid.Column="2"
                               Source="icon_filter.png"
                               HeightRequest="18"
                               WidthRequest="18"
                               VerticalOptions="Center">
                            <Image.Behaviors>
                                <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                            </Image.Behaviors>
                        </Image>
                    </Grid>
                </Border>

                <!-- Condition Chips + Sport Category Chips (single line) -->
                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="8" x:Name="ChipsRow">
                        <Border Padding="14,6"
                                x:Name="ChipAll"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectConditionCommand}"
                                                      CommandParameter="{x:Null}" />
                            </Border.GestureRecognizers>
                            <Label Text="{x:Static res:AppResources.HomeChipAll}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="13"
                                   VerticalOptions="Center" />
                        </Border>

                        <Border Padding="14,6"
                                x:Name="ChipNew"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectConditionCommand}"
                                                      CommandParameter="new" />
                            </Border.GestureRecognizers>
                            <Label Text="{x:Static res:AppResources.HomeChipNew}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="13"
                                   VerticalOptions="Center" />
                        </Border>

                        <Border Padding="14,6"
                                x:Name="ChipUsed"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectConditionCommand}"
                                                      CommandParameter="used" />
                            </Border.GestureRecognizers>
                            <Label Text="{x:Static res:AppResources.HomeChipUsed}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="13"
                                   VerticalOptions="Center" />
                        </Border>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- Hot Picks Section -->
                <VerticalStackLayout IsVisible="{Binding HasHotPicks}" Spacing="0">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                        <Label Text="{x:Static res:AppResources.HomeHotPicks}"
                               FontFamily="OpenSansSemibold"
                               FontSize="20"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                               VerticalOptions="Center" />
                        <Button Grid.Column="1"
                                Text="{x:Static res:AppResources.HomeSeeAll}"
                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                Style="{StaticResource LinkButton}"
                                VerticalOptions="Center" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding HotPicks}"
                                    HeightRequest="230">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ListingSummary">
                                <controls:ListingCardView WidthRequest="180"
                                                          Listing="{Binding}"
                                                          TapCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=GoToListingDetailCommand}"
                                                          ToggleFavoriteCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=ToggleFavoriteCommand}" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- All Products Section Header -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,4"
                      IsVisible="{Binding HasHotPicks}">
                    <VerticalStackLayout>
                        <Label Text="{x:Static res:AppResources.HomeAllProducts}"
                               FontFamily="OpenSansSemibold"
                               FontSize="20"
                               MaxLines="1"
                               LineBreakMode="NoWrap"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                        <Label FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               Text="{Binding TotalResultsText}" />
                    </VerticalStackLayout>
                    <Border Grid.Column="1"
                            Padding="12,6"
                            BackgroundColor="Transparent"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>
                        <HorizontalStackLayout Spacing="6">
                            <Image Source="{AppThemeBinding Light=icon_sort.png, Dark=icon_sort_dark.png}"
                                   HeightRequest="14"
                                   WidthRequest="14"
                                   VerticalOptions="Center" />
                            <Label Text="{x:Static res:AppResources.HomeSort}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                </Grid>

                <!-- All Products Grid -->
                <FlexLayout x:Name="ProductsGrid"
                            Wrap="Wrap"
                            Direction="Row"
                            JustifyContent="SpaceBetween"
                            BindableLayout.ItemsSource="{Binding Listings}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:ListingSummary">
                            <controls:ListingCardView Margin="0,0,0,12"
                                                      Listing="{Binding}"
                                                      TapCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=GoToListingDetailCommand}"
                                                      ToggleFavoriteCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=ToggleFavoriteCommand}" />
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>

                <!-- Empty State -->
                <Label Text="{x:Static res:AppResources.HomeEmptyListings}"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Center"
                       Margin="0,40"
                       IsVisible="{Binding IsEmpty}" />

                <!-- Bottom spacer for FAB -->
                <BoxView HeightRequest="80" Color="Transparent" />

            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />

        <Button Style="{StaticResource FloatingActionButton}"
                SemanticProperties.Description="{x:Static res:AppResources.A11yCreateListingButton}"
                Command="{Binding GoToCreateListingCommand}"
                IsVisible="{Binding IsLoggedIn}" />
    </Grid>

</ContentPage>
